{
  "name": "blogs",
  "version": "1.0.0",
  "description": "The purpose of this repository is to manage the history of my personal blog writing drafts.",
  "main": "index.js",
  "devDependencies": {
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.1",
    "textlint": "^15.5.2",
    "textlint-rule-preset-japanese": "^10.0.4"
  },
  "scripts": {
    "lint:prettier": "prettier --check .",
    "lint:markdown": "markdownlint \"**/*.md\" --ignore node_modules",
    "lint:text": "textlint \"**/*.md\"",
    "lint": "npm run lint:prettier && npm run lint:markdown && npm run lint:text",
    "format": "prettier --write .",
    "test": "npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mistbind3u88/blogs.git"
  },
  "author": "mistbind3u88",
  "license": "UNLICENSED",
  "private": true,
  "bugs": {
    "url": "https://github.com/mistbind3u88/blogs/issues"
  },
  "homepage": "https://github.com/mistbind3u88/blogs#readme",
  "overrides": {
    "katex": "0.16.11"
  }
}
